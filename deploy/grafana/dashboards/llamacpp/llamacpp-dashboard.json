      "options": {
        "mode": "markdown",
        "content": "### llama.cpp fleet\nMetrics scraped from `llama-server --metrics` (`llamacpp:*`). **Note:** llama.cpp exposes no KV-cache-usage gauge, so there is no KV panel (the autoscaler scales llama.cpp groups on running/deferred only). See `docs/llama_cpp_serve.md`."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests processing (running)",
      "description": "llamacpp:requests_processing — requests currently decoding.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 12,
            "showPoints": "never",
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "llamacpp:requests_processing{engine=\"llamacpp\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "range": true,
          "refId": "A"
        }
      ]
