      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisColorMode": "text",
            "gradientMode": "opacity"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds}"
          },
          "editorMode": "code",
          "expr": "sum(vllm:num_requests_running{model_name=~\"$model_name\", instance=~\"$instance\"})",
          "range": true,
          "refId": "A",
          "legendFormat": "running"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds}"
          },
          "editorMode": "code",
          "expr": "sum(vllm:num_requests_waiting{model_name=~\"$model_name\", instance=~\"$instance\"})",
          "range": true,
          "refId": "B",
          "legendFormat": "waiting"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Running by instance (load balance)",
