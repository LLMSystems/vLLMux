# Copy to deploy/.env and adjust. Consumed by deploy/docker-compose.yaml.

# HuggingFace token for gated/private models (leave blank for public models).
HF_TOKEN=

# Which GPUs the engine container may use: "all", or a comma list e.g. "0,1".
NVIDIA_VISIBLE_DEVICES=all

# Host ports (the browser only needs FRONTEND_PORT; the other two are for direct
# API access and can be remapped if 5000/8887 are already taken on the host).
FRONTEND_PORT=8884
BACKEND_PORT=5000
ROUTER_PORT=8887

# Password gate for model start/stop controls in the UI (baked into the build).
VITE_MODEL_CONTROL_PASSWORD=123
